<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Color Palette -->
    <Color x:Key="DarkBackgroundColor">#FF1E1E1E</Color>
    <Color x:Key="DarkSurfaceColor">#FF2D2D30</Color>
    <Color x:Key="DarkPrimaryColor">#FF007ACC</Color>
    <Color x:Key="DarkSecondaryColor">#FF005A9E</Color>
    <Color x:Key="DarkForegroundColor">#FFCCCCCC</Color>
    <Color x:Key="DarkDisabledForegroundColor">#FF666666</Color>
    <Color x:Key="DarkBorderColor">#FF3F3F46</Color>
    <Color x:Key="DarkHoverColor">#FF3E3E42</Color>
    <Color x:Key="DarkPressedColor">#FF0C6EA4</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="DarkBackgroundBrush" Color="{StaticResource DarkBackgroundColor}" />
    <SolidColorBrush x:Key="DarkSurfaceBrush" Color="{StaticResource DarkSurfaceColor}" />
    <SolidColorBrush x:Key="DarkPrimaryBrush" Color="{StaticResource DarkPrimaryColor}" />
    <SolidColorBrush x:Key="DarkSecondaryBrush" Color="{StaticResource DarkSecondaryColor}" />
    <SolidColorBrush x:Key="DarkForegroundBrush" Color="{StaticResource DarkForegroundColor}" />
    <SolidColorBrush x:Key="DarkDisabledForegroundBrush" Color="{StaticResource DarkDisabledForegroundColor}" />
    <SolidColorBrush x:Key="DarkBorderBrush" Color="{StaticResource DarkBorderColor}" />
    <SolidColorBrush x:Key="DarkHoverBrush" Color="{StaticResource DarkHoverColor}" />
    <SolidColorBrush x:Key="DarkPressedBrush" Color="{StaticResource DarkPressedColor}" />

    <!-- Theme-specific overrides for common controls -->
    <Style TargetType="{x:Type Window}">
        <Setter Property="Background" Value="{StaticResource DarkBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
    </Style>

    <Style TargetType="{x:Type Control}">
        <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
        <Setter Property="Background" Value="{StaticResource DarkSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{StaticResource DarkSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type PasswordBox}">
        <Setter Property="Background" Value="{StaticResource DarkSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="{StaticResource DarkSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type ListBox}">
        <Setter Property="Background" Value="{StaticResource DarkSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{StaticResource DarkSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource DarkHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource DarkPressedBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{StaticResource DarkDisabledForegroundBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource DarkDisabledForegroundBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type ToggleButton}">
        <Setter Property="Background" Value="{StaticResource DarkSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource DarkHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource DarkPressedBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type RadioButton}">
        <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type Label}">
        <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
    </Style>

    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
    </Style>

    <Style TargetType="{x:Type ProgressBar}">
        <Setter Property="Background" Value="{StaticResource DarkSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DarkPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type Slider}">
        <Setter Property="Foreground" Value="{StaticResource DarkPrimaryBrush}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource DarkHoverBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Scrollbar styles -->
    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Background" Value="{StaticResource DarkSurfaceBrush}" />
        <Setter Property="Width" Value="10" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="{x:Type Thumb}">
        <Setter Property="Background" Value="{StaticResource DarkPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource DarkHoverBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Expander -->
    <Style TargetType="{x:Type Expander}">
        <Setter Property="Background" Value="{StaticResource DarkSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}" />
    </Style>

    <!-- TabControl -->
    <Style TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="{StaticResource DarkSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type TabItem}">
        <Setter Property="Background" Value="{StaticResource DarkSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource DarkPrimaryBrush}" />
                <Setter Property="Foreground" Value="{StaticResource DarkBackgroundBrush}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource DarkHoverBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- GroupBox -->
    <Style TargetType="{x:Type GroupBox}">
        <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
        <Setter Property="Background" Value="{StaticResource DarkSurfaceBrush}" />
    </Style>

    <!-- ContextMenu -->
    <Style TargetType="{x:Type ContextMenu}">
        <Setter Property="Background" Value="{StaticResource DarkSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
    </Style>

    <Style TargetType="{x:Type MenuItem}">
        <Setter Property="Background" Value="{StaticResource DarkSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource DarkHoverBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Tooltip -->
    <Style TargetType="{x:Type ToolTip}">
        <Setter Property="Background" Value="{StaticResource DarkSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}" />
    </Style>
</ResourceDictionary>
