<UserControl x:Class="AGRollbackTool.DefaultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AGRollbackTool"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="800">
    <Grid>
        <Grid.Resources>
            <!-- Animation Resources -->
            <Storyboard x:Key="FadeInAnimation">
                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.0" To="1.0" Duration="0:0:0.3"/>
            </Storyboard>
            <Storyboard x:Key="FadeOutAnimation">
                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1.0" To="0.0" Duration="0:0:0.3"/>
            </Storyboard>
            <!-- Button Click Animation (Scale) -->
            <Style x:Key="AnimatedButtonStyle" TargetType="Button">
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="0.9" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="0.9" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <!-- Status Stepper Animation -->
            <Storyboard x:Key="StepActiveAnimation">
                <ColorAnimation Storyboard.TargetProperty="Fill.Color" To="#4CAF50" Duration="0:0:0.3"/>
            </Storyboard>
            <Storyboard x:Key="StepInactiveAnimation">
                <ColorAnimation Storyboard.TargetProperty="Fill.Color" To="#E0E0E0" Duration="0:0:0.3"/>
            </Storyboard>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel -->
        <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" Margin="5">
            <StackPanel Margin="10">
                 <!-- Action Buttons -->
                 <Button x:Name="BackupButton" Content="Backup" Height="40" Margin="0,0,0,10" FontSize="14" Click="BackupButton_Click" Style="{StaticResource AnimatedButtonStyle}"/>
                 <Button x:Name="RollbackButton" Content="Rollback" Height="40" Margin="0,0,0,10" FontSize="14" Click="RollbackButton_Click" Style="{StaticResource AnimatedButtonStyle}"/>
                 <Button x:Name="RestoreOnlyButton" Content="Restore Only" Height="40" Margin="0,0,0,10" FontSize="14" Click="RestoreOnlyButton_Click" Style="{StaticResource AnimatedButtonStyle}"/>

                 <!-- File Picker -->
                 <GroupBox Header="Installer Selection" Margin="0,0,0,10">
                     <StackPanel>
                         <TextBox x:Name="InstallerPathTextBox" Height="25" Margin="0,0,0,5" IsReadOnly="True"/>
                         <Button Content="Browse..." Height="30" Click="BrowseButton_Click" Style="{StaticResource AnimatedButtonStyle}"/>
                     </StackPanel>
                 </GroupBox>

                 <!-- Backup Browser -->
                 <GroupBox Header="Past Backups" Margin="0,0,0,10">
                     <ListView x:Name="BackupListView" Height="150">
                         <ListView.View>
                             <GridView>
                                 <GridViewColumn Header="Date" Width="120" DisplayMemberBinding="{Binding Timestamp}"/>
                                 <GridViewColumn Header="Version" Width="100" DisplayMemberBinding="{Binding Version}"/>
                                 <GridViewColumn Header="Status" Width="80" DisplayMemberBinding="{Binding Status}"/>
                             </GridView>
                         </ListView.View>
                     </ListView>
                 </GroupBox>

                 <!-- Settings Button -->
                 <Button x:Name="SettingsButton" Content="Settings" Height="40" Margin="0,10,0,0" FontSize="14" Click="SettingsButton_Click" Style="{StaticResource AnimatedButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- Center Panel - Status Stepper -->
        <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1" Margin="5">
            <StackPanel Margin="20" VerticalAlignment="Center">
                <TextBlock Text="Rollback Process" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <!-- Step 1: Preparation -->
                    <StackPanel Orientation="Vertical">
                        <Ellipse x:Name="Step1Ellipse" Width="20" Height="20" Fill="#E0E0E0" Stroke="#999999" StrokeThickness="1"/>
                        <TextBlock Text="Prepare" FontSize="12" TextAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                    <Line X1="0" Y1="10" X2="40" Y2="10" Stroke="#CCCCCC" StrokeThickness="2"/>
                    <!-- Step 2: Backup -->
                    <StackPanel Orientation="Vertical">
                        <Ellipse x:Name="Step2Ellipse" Width="20" Height="20" Fill="#E0E0E0" Stroke="#999999" StrokeThickness="1"/>
                        <TextBlock Text="Backup" FontSize="12" TextAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                    <Line X1="0" Y1="10" X2="40" Y2="10" Stroke="#CCCCCC" StrokeThickness="2"/>
                    <!-- Step 3: Rollback -->
                    <StackPanel Orientation="Vertical">
                        <Ellipse x:Name="Step3Ellipse" Width="20" Height="20" Fill="#E0E0E0" Stroke="#999999" StrokeThickness="1"/>
                        <TextBlock Text="Rollback" FontSize="12" TextAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                    <Line X1="0" Y1="10" X2="40" Y2="10" Stroke="#CCCCCC" StrokeThickness="2"/>
                    <!-- Step 4: Verification -->
                    <StackPanel Orientation="Vertical">
                        <Ellipse x:Name="Step4Ellipse" Width="20" Height="20" Fill="#E0E0E0" Stroke="#999999" StrokeThickness="1"/>
                        <TextBlock Text="Verify" FontSize="12" TextAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock x:Name="StatusTextBlock" Text="Ready" FontSize="14" HorizontalAlignment="Center" Margin="0,20,0,0" Foreground="#666666"/>
                <ProgressBar x:Name="ProgressBar" Height="20" Width="200" Margin="0,10,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
